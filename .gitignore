# 🎨 InteractiveLED - .gitignore

# ========================================
# 📦 Dépendances et Modules
# ========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ========================================
# 🔧 Fichiers de Configuration
# ========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Configuration locale
config.local.js
settings.local.json

# ========================================
# 🖥️ Système d'Exploitation
# ========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ========================================
# 🚀 Développement et Build
# ========================================
# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage
.grunt

# Bower dependency directory
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons
build/Release

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# ========================================
# 🎨 Modèles ML et Données
# ========================================
# Modèles ONNX (peuvent être volumineux)
public/models/*.onnx
public/models/*.bin
public/models/*.safetensors
public/models/*.pth
public/models/*.pt

# Images de style (peuvent être volumineuses)
public/styles/*.jpg
public/styles/*.jpeg
public/styles/*.png
public/styles/*.gif
public/styles/*.webp

# Données d'entraînement
data/
datasets/
models/
weights/
checkpoints/

# Cache des modèles
.cache/
model_cache/
onnx_cache/

# ========================================
# 🧪 Tests et Développement
# ========================================
# Tests
test-results/
coverage/
.nyc_output/

# IDE et Éditeurs
.vscode/
.idea/
*.swp
*.swo
*~

# Éditeurs de code
.vscode/
.idea/
*.swp
*.swo
*~

# ========================================
# 📱 Développement Mobile
# ========================================
# Capacitor
android/
ios/
dist/

# Cordova
platforms/
plugins/

# ========================================
# 🔒 Sécurité
# ========================================
# Clés et tokens
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der

# Fichiers de configuration sensibles
secrets.json
auth.json
credentials.json

# ========================================
# 📊 Monitoring et Analytics
# ========================================
# Logs d'application
app.log
error.log
access.log

# Métriques et monitoring
metrics/
stats/

# ========================================
# 🚀 Production et Déploiement
# ========================================
# Builds de production
build/
dist/
out/

# Fichiers de déploiement
.deploy/
deploy/

# ========================================
# 🧹 Fichiers Temporaires
# ========================================
# Fichiers temporaires
*.tmp
*.temp
*.bak
*.backup
*.old

# Fichiers de téléchargement
downloads/
downloaded_*

# ========================================
# 📝 Documentation Générée
# ========================================
# Documentation auto-générée
docs/generated/
api-docs/

# ========================================
# 🎯 Fichiers Spécifiques au Projet
# ========================================
# Scripts de téléchargement temporaires
download-*.js
search-*.js
create-*.js

# Tests temporaires
test-*.js
simple-*.js

# Guides obsolètes
download-*.md

# ========================================
# ✅ Exceptions (Fichiers à Garder)
# ========================================
!public/models/.gitkeep
!public/styles/.gitkeep
!package.json
!package-lock.json
!README.md
!server.js
!public/*.html
!public/*.js

# ========================================
# 📋 Notes
# ========================================
# Ce .gitignore est optimisé pour :
# - Projets Node.js
# - Applications ML/IA avec ONNX
# - Développement web interactif
# - Gestion des modèles volumineux
# - Sécurité des données sensibles
